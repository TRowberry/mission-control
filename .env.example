# Database
DATABASE_URL="file:./dev.db"
# For PostgreSQL: DATABASE_URL="postgresql://user:password@localhost:5432/mission_control"

# Agent API (for connecting AI agents like Rico)
# Create agents via: node scripts/create-agent.js <username> <displayName> <email>
# RICO_API_KEY=mc_agent_xxxxx

# Auth
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_WS_URL="ws://localhost:3001"

# File uploads (optional)
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE="10485760"

# Research Agent (running on GraySkull)
RESEARCH_AGENT_URL="http://10.0.0.206:18800"
RESEARCH_AGENT_KEY="your_research_agent_key_here"
